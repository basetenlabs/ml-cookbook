# Autoresearch Fine-Tuning - Experiment Configuration
# This is the ONLY file the agent modifies during the experiment loop.
# Each variable maps to a megatron sft CLI flag in run.sh.

# LoRA Configuration
LORA_RANK=8
LORA_ALPHA=16
LORA_DROPOUT=0.0
TARGET_MODULES=all-linear

# Optimization
LR=1e-4
MIN_LR=1e-5
LR_WARMUP_FRACTION=0.05
WEIGHT_DECAY=0.01
MICRO_BATCH_SIZE=1
GLOBAL_BATCH_SIZE=8
TRAIN_ITERS=100

# Memory Management
RECOMPUTE_GRANULARITY=full
RECOMPUTE_METHOD=uniform
RECOMPUTE_NUM_LAYERS=2
OPTIMIZER_CPU_OFFLOAD=true
SEQUENCE_PARALLEL=true
MAX_LENGTH=4096

# Data
PACKING=true
NUM_WORKERS=8
DATASET_NUM_PROC=8
