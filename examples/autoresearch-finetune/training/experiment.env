# Iter5 Exp5: LR 8e-4, rank 64, max_length 8192, warmup 0.1, wd 0.005
LORA_RANK=64
LORA_ALPHA=128
LORA_DROPOUT=0.0
TARGET_MODULES=all-linear
LR=8e-4
MIN_LR=8e-5
LR_WARMUP_FRACTION=0.1
WEIGHT_DECAY=0.005
MICRO_BATCH_SIZE=1
GLOBAL_BATCH_SIZE=16
TRAIN_ITERS=100
RECOMPUTE_GRANULARITY=full
RECOMPUTE_METHOD=uniform
RECOMPUTE_NUM_LAYERS=4
OPTIMIZER_CPU_OFFLOAD=true
SEQUENCE_PARALLEL=true
MAX_LENGTH=8192
PACKING=true
NUM_WORKERS=8
DATASET_NUM_PROC=8
