# Autoresearch Fine-Tuning on Baseten - Configuration
# Edit these values before running. All have sensible defaults.

# Model
MODEL=Qwen/Qwen3-8B              # Any HuggingFace model path
MODEL_TYPE=                       # MS-Swift model type (leave empty for auto-detect, set for custom/new architectures)

# Dataset
DATASET=winglian/pirate-ultrachat-10k  # HuggingFace dataset path
EVAL_SPLIT_RATIO=0.01            # Fraction held out for validation

# Compute
ACCELERATOR=H100                  # GPU type: H100, H200, A100
GPU_COUNT=2                       # GPUs per training job

# Autoresearch
PARALLEL_JOBS=2                   # 1 = sequential, 2-5 = parallel experiment batches
TOTAL_BUDGET=25                   # Total experiment limit (0 = unlimited)
RUN_TAG=run1                      # Branch name: autoresearch/<tag>

# Baseten
REMOTE=baseten                    # truss remote name (from ~/.trussrc)
TEAM=                             # Baseten team name (if multiple teams)
PROJECT_NAME=autoresearch-finetune
